<launch>
  <!-- nrt low-level node: read libsurvive topics -> localize (vive_world anchor +
       mobile_base) -> broadcast TF + XDDP bridge (odom + forwarded cmd_vel). -->
  <arg name="config" default="$(find hyumm_nrt)/config/vive_xddp.yaml"/>
  <arg name="send_xddp" default="false"/>     <!-- true: stream odom + cmd_vel to the RT side -->
  <arg name="recv_status" default="false"/>   <!-- true: receive rt NOMINAL base status (green robot) -->

  <node pkg="hyumm_nrt" type="hyumm_vive_xddp_node" name="hyumm_vive_xddp" output="screen">
    <rosparam command="load" file="$(arg config)"/>
    <param name="send_xddp" value="$(arg send_xddp)"/>
    <param name="recv_status" value="$(arg recv_status)"/>
  </node>
</launch>
