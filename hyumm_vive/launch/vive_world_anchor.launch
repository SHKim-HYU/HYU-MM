<launch>
  <!-- Define vive_world from the fixed reference tracker and republish vive
       poses in vive_world. Consumes the vive_libsurvive_ros backend topics.
       Usage: roslaunch hyumm_vive vive_world_anchor.launch -->

  <arg name="config" default="$(find hyumm_vive)/config/anchor.yaml"/>

  <node pkg="hyumm_vive" type="vive_world_anchor_node" name="vive_world_anchor"
        output="screen">
    <rosparam command="load" file="$(arg config)"/>
  </node>
</launch>
